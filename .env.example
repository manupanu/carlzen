OPENAI_API_KEY=your_openai_api_key_here

# AI model to use. Defaults to gpt-4o.
# Examples: gpt-4o, gpt-4.1, llama-3.3-70b-versatile (Groq)
# AI_MODEL=gpt-4o

# Base URL for the OpenAI-compatible API endpoint.
# Leave unset to use the default OpenAI endpoint.
# Examples:
#   Groq:    https://api.groq.com/openai/v1
#   Ollama:  http://localhost:11434/v1
# AI_BASE_URL=https://api.groq.com/openai/v1

# Port the Node.js server listens on inside the container (also used as container port in compose)
PORT=3000

# Port exposed on the host machine (maps to PORT inside the container)
HOST_PORT=8080

# Docker restart policy: no | always | on-failure | unless-stopped
RESTART_POLICY=always

# Node environment: production | development
NODE_ENV=production
